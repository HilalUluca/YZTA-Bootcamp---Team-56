# FocusForge Backend

# Veritabanı (Geliştirme: SQLite, Production: PostgreSQL)
# PostgreSQL için: postgresql://postgres:postgres@localhost:5432/focusforge
DATABASE_URL=sqlite:///./focusforge.db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
SECRET_KEY=focusforge-super-secret-key-degistirmeyi-unutma
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Gemini API
GEMINI_API_KEY=buraya-gemini-api-key-yazilacak

# Uygulama
APP_NAME=FocusForge
DEBUG=True
